{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "serviceBus": {
            "prefetchCount": 0,
            "maxConcurrentCalls": 16,
            "autoCompleteMessages": false,
            "maxDeliveryCount": 3
        }
    }
}